<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Второй экран"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <!-- Текстовое поле для информации -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Информация о студенте:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <!-- Поле для ввода ФИО -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ФИО:"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/editTextFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите ФИО полностью"
            android:inputType="textPersonName"
            android:padding="10dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="15dp"/>

        <!-- Поле для ввода группы -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Номер группы:"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/editTextGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Например: ИСП-201"
            android:inputType="text"
            android:padding="10dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="15dp"/>

        <!-- Поле для ввода возраста -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Возраст:"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/editTextAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите возраст"
            android:inputType="number"
            android:padding="10dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="15dp"/>

        <!-- Поле для ввода оценки -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Желаемая оценка:"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/editTextGrade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите оценку (5, 10 и т.д.)"
            android:inputType="number"
            android:padding="10dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="25dp"/>

        <!-- Кнопка отправки -->
        <Button
            android:id="@+id/buttonSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отправить данные"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="15dp"/>
        <!-- Еще одна картинка для демонстрации -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Изображение:"
            android:textSize="16sp"
            android:layout_marginBottom="5dp"/>

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_dialog_info"
            android:scaleType="centerInside"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>
</ScrollView>